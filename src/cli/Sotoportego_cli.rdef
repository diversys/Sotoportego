resource app_signature "application/x-vnd.VePro-SotoportegoCLI";

resource app_version {
	major		= 0,
	middle		= 1,
	minor		= 0,
	variety		= B_APPV_DEVELOPMENT,
	internal	= 0,
	short_info	= "Sotoportego CLI",
	long_info	= "Sotoportego command-line test client for the VPN daemon."
};

resource app_flags B_MULTIPLE_LAUNCH;

// Same HVIF as the GUI so the family of binaries shares a single visual
// identity in Tracker / Deskbar.
resource(101, "BEOS:ICON") #'VICN' import "../../Sotoportego.hvif";
